# Pinchtab Environment Configuration
# Copy this file to .env and fill in your actual credentials.
# NEVER COMMIT YOUR .ENV FILE TO VERSION CONTROL.

# --- Bridge Authentication ---
# A strong secret token for the bridge server. 
# Clients must provide this token to connect.
PINCHTAB_TOKEN=your-strong-secret-token-here

# --- Server Settings ---
# PINCHTAB_BIND=127.0.0.1
# PINCHTAB_PORT=9867

# --- Integration Credentials (Custom) ---
# Example credentials if you use custom login scripts for platforms
# GITHUB_USER=
# GITHUB_PASS=
# LINKEDIN_USER=
# LINKEDIN_PASS=

# --- Path Settings ---
# CHROME_BIN=/usr/bin/google-chrome
